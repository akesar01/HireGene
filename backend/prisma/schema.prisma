// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge function?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════════════════

enum JobSource {
  linkedin
  x
}

enum RoleFamily {
  engineering
  ai_ml
  product
  design
  data
  growth
  marketing
  content
  ops
  founders_office
  sales
  strategy
  finance
  business
  people
}

enum SeniorityLevel {
  intern
  junior
  mid
  senior
  lead
  staff
  head
}

enum RemoteMode {
  in_office
  remote
  hybrid
}

enum TechStack {
  python
  java
  sql
  ai
  aws
  langchain
  rag
  react
  llm
  nextjs
  typescript
  nodejs
  go
  rust
  docker
}

// ═══════════════════════════════════════════════════════════════════════════════
// RECRUITER MODEL
// ═══════════════════════════════════════════════════════════════════════════════

model Recruiter {
  id                 Int      @id @default(autoincrement())
  name               String
  linkedinUrl        String   @unique @map("linkedin_url")
  active             Boolean  @default(true)

  // Configurable cadence for future cron automation (v2).
  // In v1, scrapes are triggered manually. Stored for forward-compat.
  scrapeIntervalHours Int     @default(24) @map("scrape_interval_hours")

  addedAt            DateTime  @default(now()) @map("added_at")
  lastScrapedAt      DateTime? @map("last_scraped_at")

  // Relations
  jobs               Job[]
  apifyRuns          ApifyRunLog[]

  @@index([active, lastScrapedAt]) // future cron query + list endpoint filtering
  @@map("recruiters")
}

// ═══════════════════════════════════════════════════════════════════════════════
// RECRUITER SUBMISSION MODEL (human-in-the-loop review)
// ═══════════════════════════════════════════════════════════════════════════════

enum SubmissionStatus {
  pending
  approved
  rejected
}

model RecruiterSubmission {
  id              Int              @id @default(autoincrement())
  name            String
  linkedinUrl     String           @map("linkedin_url")
  company         String?
  title           String?          // e.g. "Engineering Manager @ Google"
  note            String?          // optional context from submitter
  submittedByIp   String?          @map("submitted_by_ip")
  status          SubmissionStatus @default(pending)
  reviewedAt      DateTime?        @map("reviewed_at")
  recruiterId     Int?             @map("recruiter_id") // set when approved
  createdAt       DateTime         @default(now()) @map("created_at")

  @@index([status])
  @@index([linkedinUrl])
  @@map("recruiter_submissions")
}

// ═══════════════════════════════════════════════════════════════════════════════
// JOB MODEL
// ═══════════════════════════════════════════════════════════════════════════════

model Job {
  id            Int      @id @default(autoincrement())

  // Foreign key
  recruiterId   Int      @map("recruiter_id")
  recruiter     Recruiter @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  votes         Vote[]

  // Core fields
  title         String
  company       String
  author        String
  authorTitle   String   @map("author_title")
  authorAvatar  String?  @map("author_avatar")
  roleBadge     String   @map("role_badge")

  // Source
  source        JobSource
  sourceUrl     String   @unique @map("source_url") // idempotent dedup key

  // True if the recruiter shared/reposted someone else's post.
  // author still = the recruiter (per product decision), this just flags it.
  isRepost      Boolean  @default(false) @map("is_repost")

  // Structured attributes
  roleFamily    RoleFamily @map("role_family")
  seniority     SeniorityLevel
  remoteMode    RemoteMode @map("remote_mode")
  stack         TechStack[]

  // Content
  description   String[]
  rawText       String   @map("raw_text") // original post text; enables future LLM re-parse

  // Hash of rawText. On re-scrape, if the URL exists but the hash differs,
  // the post was edited -> we can UPDATE instead of skipping. Cheap edit detection.
  contentHash   String   @map("content_hash")

  // Community engagement
  commentCount  Int      @default(0) @map("comment_count")
  score         Int      @default(0) // net upvotes - downvotes

  // Lifecycle
  postedAt      DateTime @map("posted_at")
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  // Indexes
  @@index([expiresAt])
  @@index([source, roleFamily, seniority, remoteMode])
  @@index([commentCount(sort: Desc)])
  @@index([score(sort: Desc)])
  @@index([postedAt(sort: Desc)])
  @@index([recruiterId])

  @@map("jobs")
}

// ═══════════════════════════════════════════════════════════════════════════════
// VOTE MODEL (IP-based dedup, one vote per IP per job)
// ═══════════════════════════════════════════════════════════════════════════════

model Vote {
  id        Int      @id @default(autoincrement())
  jobId     Int      @map("job_id")
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  voterIp   String   @map("voter_ip")
  direction String   // "up" | "down"
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([jobId, voterIp])
  @@index([jobId])
  @@map("votes")
}

// ═══════════════════════════════════════════════════════════════════════════════
// APIFY RUN LOG MODEL
// ═══════════════════════════════════════════════════════════════════════════════

model ApifyRunLog {
  id            Int      @id @default(autoincrement())
  recruiterId   Int?     @map("recruiter_id")
  recruiter     Recruiter? @relation(fields: [recruiterId], references: [id], onDelete: SetNull)

  apifyRunId    String   @unique @map("apify_run_id")
  actorId       String   @map("actor_id")
  source        JobSource

  status        String   // "RUNNING" | "SUCCEEDED" | "FAILED" | "TIMED-OUT"
  postsFound    Int      @default(0) @map("posts_found")
  jobsCreated   Int      @default(0) @map("jobs_created")
  jobsSkipped   Int      @default(0) @map("jobs_skipped")

  startedAt     DateTime @map("started_at")
  finishedAt    DateTime? @map("finished_at")

  errorMsg      String?  @map("error_msg")

  @@map("apify_run_logs")
}
